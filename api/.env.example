# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bouncer
DB_USER=bouncer
DB_PASSWORD=bouncer_password

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Authentication
#   AUTH_MODE=mock  — trust X-Actor-Uid header (default, dev-friendly)
#   AUTH_MODE=oidc  — require Bearer JWT on every non-public route
AUTH_MODE=mock

# OIDC settings (only used when AUTH_MODE=oidc).
# Point at the dev Keycloak realm by default; switch the issuer to your
# Okta authorization server URL for production.
OIDC_ISSUER=http://localhost:8080/realms/bouncer
OIDC_AUDIENCE=bouncer-ui
