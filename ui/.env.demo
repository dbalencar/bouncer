# Bouncer UI — DEMO (mock-subject) mode
#
# Activate by symlinking this file to .env:
#   cd ui && ln -sf .env.demo .env
#
# In this mode the Login button shows a dropdown of seeded demo subjects.
# Axios sends X-Actor-Uid on every API call.
# Keep this in sync with api/.env's AUTH_MODE.

VITE_DEMO_MODE=true
VITE_AUTH_MODE=mock
