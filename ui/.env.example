VITE_DEMO_MODE=true

# Authentication
#   VITE_AUTH_MODE=mock — keep mocked-subject login UI (default)
#   VITE_AUTH_MODE=oidc — redirect to the configured IdP on Login click
# The UI also reads /auth/config from the API at startup, so the build-
# time value is just a hint for the initial render.
VITE_AUTH_MODE=mock

# OIDC settings (only used when VITE_AUTH_MODE=oidc).
# Point at the dev Keycloak realm by default; for Okta, replace with
# your authorization server URL and update the client id.
VITE_OIDC_ISSUER=http://localhost:8080/realms/bouncer
VITE_OIDC_CLIENT_ID=bouncer-ui
